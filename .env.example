APP_NAME=Employee Shipment Tracker
DATABASE_URL=sqlite:///./employee_shipments.db

# Replace this with a long random value in production.
JWT_SECRET_KEY=change-this-development-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=60
JWT_COOKIE_SECURE=false

# Keep true until you have registered and received a RajaOngkir API key.
RAJAONGKIR_MOCK=true
RAJAONGKIR_API_KEY=
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1

# Used to convert login latitude/longitude into readable address details.
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
GEOCODER_USER_AGENT=employee-shipment-tracker-demo/1.0
